# 复制一份命名为「.env」用作用户配置信息
# 优先级：系统/部署环境变量 > 根目录 .env > 代码默认值

# 站点信息
BLOG_TITLE="XG-Blog"
BLOG_SUBTITLE="记录与分享~ 使用纯静态 XG-Blog！"
BLOG_LOGO="/default/default-logo.svg"
BLOG_LOGO_DARK="/default/default-logo-dark.svg"

# SEO 信息
SEO_DESCRIPTION="这里填写站点描述，用于首页和 SEO。"
SEO_KEYWORDS="XG-Blog, 静态博客, 个人博客"

# 是否显示 LOGO 旁站点标题，默认关闭；设置为 true 开启。
BLOG_SHOW_TITLE="false"

# URL 影响 sitemap、RSS、robots 的生成
BLOG_URL="https://example.com"

# 主题设置
THEME_COLOR="#2D96E4"

# 博主信息「首页卡片」
BLOG_AUTHOR="博主昵称"
BLOG_AVATAR="/default/default-user.svg"
BLOG_BIO="这里填写博主简介。"

# 是否将博主头像裁成圆形，默认（无变量、空值时候）开启；设置为 false 关闭。
BLOG_AVATAR_CIRCLE="true"

# 备案信息
# BEIAN="粤ICP备1234567890号"
# BEIAN_URL="http://beian.miit.gov.cn/"

# 评论系统（Twikoo）
# 留空表示不启用；启用时填写你的 Twikoo 服务地址，例如 https://twikoo.example.com
# TWIKOO_ENV_ID=""

# Twikoo js CDN，一般不用改；程序默认 twikoo 1.7.12（jsdelivr）
TWIKOO_JS_URL="https://cdn.jsdelivr.net/npm/twikoo@1.7.12/dist/twikoo.min.js"

# 国内访问默认 CDN 不稳定时，可改为：
# https://registry.npmmirror.com/twikoo/1.7.12/files/dist/twikoo.min.js
# https://s4.zstatic.net/npm/twikoo@1.7.12/dist/twikoo.min.js
