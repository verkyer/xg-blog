# 站点基础信息
# 优先级：系统/部署环境变量 > 根目录 .env > 代码默认值
# 布尔开关可用 true/false、1/0、yes/no、on/off；空值使用默认值。
BLOG_TITLE="示例博客"
BLOG_SUBTITLE="记录与分享"
BLOG_DESCRIPTION="这里填写站点描述，用于首页和 SEO。"
BLOG_URL="https://example.com"
BLOG_LOGO="/default/default-logo.svg"
BLOG_LOGO_DARK="/default/default-logo.svg"
# 是否显示站点标题，默认开启。
BLOG_SHOW_TITLE="true"

# 主题设置
THEME_COLOR="#2D96E4"

# 博主信息
BLOG_AUTHOR="博主昵称"
BLOG_AVATAR="/default/default-user.svg"
# 是否将博主头像裁成圆形，默认开启；设置为 false 关闭。
BLOG_AVATAR_CIRCLE="true"
BLOG_BIO="这里填写博主简介。"
