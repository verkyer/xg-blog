---
import SeoHead from '../components/SeoHead.astro';
import SearchDialog from '../components/SearchDialog.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { headData } from '../../features/core/data';
import { getSite } from '../../features/core/seo';
import globalStylesheet from '../styles/global.css?url';

interface Props {
  title?: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
}

const { title, description, canonical, image, type, publishedTime } = Astro.props;
const site = getSite();
---

<!doctype html>
<html lang="zh-CN" style={`--theme-color: ${site.theme.color};`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (() => {
        try {
          const theme = localStorage.getItem('theme');
          if (theme === 'light' || theme === 'dark') {
            document.documentElement.dataset.theme = theme;
          }
        } catch {
          // Keep the system preference when storage is unavailable.
        }
      })();
    </script>
    <link rel="stylesheet" href={globalStylesheet} />
    <SeoHead title={title} description={description} canonical={canonical} image={image} type={type} publishedTime={publishedTime} />
    {headData.map((html) => <Fragment set:html={html} />)}
  </head>
  <body>
    <SiteHeader currentPath={Astro.url.pathname} />
    <SearchDialog />
    <main>
      <slot />
    </main>
    <SiteFooter />
    <button class="jump-to-comments" type="button" aria-label="跳转到评论区" data-jump-to-comments aria-hidden="true" tabindex="-1" hidden>
      <svg class="jump-to-comments-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"></path>
      </svg>
    </button>
    <button class="back-to-top" type="button" aria-label="返回顶部" data-back-to-top aria-hidden="true" tabindex="-1">
      <svg class="back-to-top-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m18 15-6-6-6 6"></path>
      </svg>
    </button>
    <script>
      const backToTop = document.querySelector<HTMLButtonElement>('[data-back-to-top]');
      const jumpToComments = document.querySelector<HTMLButtonElement>('[data-jump-to-comments]');
      const commentsPanel = document.querySelector<HTMLElement>('#comments');

      if (jumpToComments && commentsPanel) {
        jumpToComments.hidden = false;
      }

      if (backToTop) {
        const syncFloatingActions = () => {
          const visible = window.scrollY > 420;
          backToTop.classList.toggle('is-visible', visible);
          backToTop.setAttribute('aria-hidden', String(!visible));
          backToTop.tabIndex = visible ? 0 : -1;

          if (jumpToComments && commentsPanel) {
            jumpToComments.classList.toggle('is-visible', visible);
            jumpToComments.setAttribute('aria-hidden', String(!visible));
            jumpToComments.tabIndex = visible ? 0 : -1;
          }
        };

        backToTop.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        jumpToComments?.addEventListener('click', () => {
          commentsPanel?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });

        window.addEventListener('scroll', syncFloatingActions, { passive: true });
        syncFloatingActions();
      }
    </script>
  </body>
</html>
