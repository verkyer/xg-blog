---
import type { Post } from '../../features/core/posts';
import { getAllTags } from '../../features/core/taxonomy';

interface Props {
  counts: Map<string, number>;
  posts: Post[];
  limit?: number;
}

const { counts, posts, limit = 20 } = Astro.props;
const tags = await getAllTags(posts);
const sorted = [...tags].sort((a, b) => {
  const countDiff = (counts.get(b.slug) ?? 0) - (counts.get(a.slug) ?? 0);
  return countDiff || a.name.localeCompare(b.name, 'zh-CN');
});
const visible = sorted.slice(0, limit);
---

<section class="sidebar-card tag-card" aria-labelledby="tag-title">
  <div class="section-heading">
    <h2 class="title-with-icon" id="tag-title">
      <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M13.172 2a2 2 0 0 1 1.414.586l6.71 6.71a2.4 2.4 0 0 1 0 3.408l-4.592 4.592a2.4 2.4 0 0 1-3.408 0l-6.71-6.71A2 2 0 0 1 6 9.172V3a1 1 0 0 1 1-1z" />
        <path d="M2 7v6.172a2 2 0 0 0 .586 1.414l6.71 6.71a2.4 2.4 0 0 0 3.191.193" />
        <circle cx="10.5" cy="6.5" r=".5" fill="currentColor" />
      </svg>
      TOP 标签
    </h2>
    <a class="more-link" href="/tags">更多</a>
  </div>
  <div class="tag-cloud">
    {visible.map((tag) => (
      <a href={`/tags/${tag.slug}`}>#{tag.name}<small>{counts.get(tag.slug) ?? 0}</small></a>
    ))}
  </div>
</section>
