---
import { menuData } from '../../features/core/data';
import { getSite } from '../../features/core/seo';

interface Props {
  currentPath: string;
}

const site = getSite();
const navItems = menuData;
const { currentPath } = Astro.props;
const xgBlogVersion = 'v0.5.7';

const normalizeTarget = (target?: string | null) => (target === 'blank' || target === '_blank' ? '_blank' : undefined);
const normalizeHref = (href?: string | null) => href?.trim() ?? '';
const isActiveHref = (href: string) => Boolean(href) && (currentPath === href || (href !== '/' && currentPath.startsWith(href)));
---

<header class:list={['site-header', { 'has-icon-only-brand': !site.showTitle }]} data-site-header>
  <div class="container header-inner">
    <a class:list={['brand', { 'icon-only': !site.showTitle }]} href="/" aria-label={`${site.title} 首页`}>
      <img src={site.logo} data-light-logo={site.logo} data-dark-logo={site.darkLogo} alt={`${site.title} logo`} width="44" height="44" data-brand-logo />
      {site.showTitle && <strong>{site.title}</strong>}
    </a>
    <nav class="top-nav" id="site-nav" aria-label="站点导航" data-site-nav hidden>
      {navItems.map((item, index) => {
        const subItems = item.sub ?? [];
        const hasChildren = subItems.length > 0;
        const itemHref = normalizeHref(item.href);
        const itemTarget = normalizeTarget(item.target);
        const itemRel = itemTarget ? 'noopener noreferrer' : undefined;
        const hasActiveChild = subItems.some((child) => isActiveHref(normalizeHref(child.href)));
        const selfActive = isActiveHref(itemHref);
        const active = selfActive || hasActiveChild;
        const submenuId = `submenu-${index}`;

        return (
          <div class:list={['nav-item', { active, 'has-children': hasChildren, 'has-active-child': hasActiveChild }]}>
            {itemHref ? (
              <a href={itemHref} target={itemTarget} rel={itemRel} class:list={['nav-link', { active: selfActive && !hasActiveChild }]}>
                {item.label}
                {hasChildren && (
                  <svg class="nav-chevron-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m6 9 6 6 6-6" />
                  </svg>
                )}
              </a>
            ) : hasChildren ? (
              <button
                class:list={['nav-link', { active: selfActive && !hasActiveChild }]}
                type="button"
                aria-label={`展开${item.label}子菜单`}
                aria-controls={submenuId}
                aria-expanded="false"
                data-submenu-toggle
              >
                {item.label}
                <svg class="nav-chevron-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m6 9 6 6 6-6" />
                </svg>
              </button>
            ) : (
              <span class:list={['nav-link', { active: selfActive && !hasActiveChild }]}>
                {item.label}
              </span>
            )}
            {hasChildren && (
              <>
                <button
                  class="submenu-toggle icon-button"
                  type="button"
                  aria-label={`展开${item.label}子菜单`}
                  aria-controls={submenuId}
                  aria-expanded="false"
                  data-submenu-toggle
                >
                  <svg class="swap-icon submenu-expand-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m6 9 6 6 6-6" />
                  </svg>
                  <svg class="swap-icon submenu-collapse-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="m18 15-6-6-6 6" />
                  </svg>
                </button>
                <div class="submenu" id={submenuId} data-submenu>
                  {subItems.map((child) => {
                    const childHref = normalizeHref(child.href);
                    const childTarget = normalizeTarget(child.target);
                    const childRel = childTarget ? 'noopener noreferrer' : undefined;
                    const childActive = isActiveHref(childHref);
                    return childHref ? (
                      <a href={childHref} target={childTarget} rel={childRel} class:list={['submenu-link', { active: childActive }]}>
                        {child.label}
                      </a>
                    ) : (
                      <span class:list={['submenu-link', { active: childActive }]}>
                        {child.label}
                      </span>
                    );
                  })}
                </div>
              </>
            )}
          </div>
        );
      })}
      <div class="mobile-nav-links" aria-label="站点工具">
        <a href="/rss.xml" aria-label="RSS" class="mobile-nav-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 11a9 9 0 0 1 9 9" />
            <path d="M4 4a16 16 0 0 1 16 16" />
            <circle cx="5" cy="19" r="1" />
          </svg>
          RSS
        </a>
        <a href="/sitemap.xml" aria-label="网站地图" class="mobile-nav-link">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.382V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z" />
            <path d="M15 5.764v15" />
            <path d="M9 3.236v15" />
          </svg>
          网站地图
        </a>
        <a
          href="https://github.com/verkyer/xg-blog"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={xgBlogVersion}
          class="mobile-nav-link"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 16v-4" />
            <path d="M12 8h.01" />
          </svg>
          {xgBlogVersion}
        </a>
      </div>
    </nav>
    <div class="header-actions">
      <button class="search-toggle icon-button" type="button" aria-label="搜索文章" data-search-open>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
      </button>
      <button class="theme-toggle icon-button" type="button" aria-label="切换深浅色主题" data-theme-toggle>
        <svg class="swap-icon theme-moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z" />
        </svg>
        <svg class="swap-icon theme-sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4" />
          <path d="M12 2v2" />
          <path d="M12 20v2" />
          <path d="m4.93 4.93 1.41 1.41" />
          <path d="m17.66 17.66 1.41 1.41" />
          <path d="M2 12h2" />
          <path d="M20 12h2" />
          <path d="m6.34 17.66-1.41 1.41" />
          <path d="m19.07 4.93-1.41 1.41" />
        </svg>
      </button>
      <button class="nav-toggle icon-button" type="button" aria-label="打开导航菜单" aria-controls="site-nav" aria-expanded="false" data-nav-toggle>
        <svg class="swap-icon nav-menu-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 6h16" />
          <path d="M4 12h16" />
          <path d="M4 18h16" />
        </svg>
        <svg class="swap-icon nav-close-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18" />
          <path d="m6 6 12 12" />
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-site-header]');
  const nav = header?.querySelector<HTMLElement>('[data-site-nav]');
  const navToggle = header?.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const themeToggle = header?.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  const brandLogo = header?.querySelector<HTMLImageElement>('[data-brand-logo]');
  const submenuToggles = Array.from(header?.querySelectorAll<HTMLButtonElement>('[data-submenu-toggle]') ?? []);
  const submenuItems = Array.from(header?.querySelectorAll<HTMLElement>('.nav-item.has-children') ?? []);
  const media = window.matchMedia('(prefers-color-scheme: dark)');
  const mobileNav = window.matchMedia('(max-width: 720px)');
  const touchNav = window.matchMedia('(hover: none), (pointer: coarse)');

  const getStoredTheme = () => {
    try {
      const theme = localStorage.getItem('theme');
      return theme === 'light' || theme === 'dark' ? theme : null;
    } catch {
      return null;
    }
  };

  const getEffectiveTheme = () => document.documentElement.dataset.theme || (media.matches ? 'dark' : 'light');
  const usesClickSubmenus = () => mobileNav.matches || touchNav.matches;

  const syncOpenSubmenuClass = () => {
    const hasOpenSubmenu = Boolean(nav?.querySelector('.nav-item.is-submenu-open'));
    nav?.classList.toggle('has-open-submenu', hasOpenSubmenu);
  };

  const syncBrandLogo = () => {
    if (!brandLogo) return;
    const lightLogo = brandLogo.dataset.lightLogo;
    const darkLogo = brandLogo.dataset.darkLogo || lightLogo;
    const nextLogo = getEffectiveTheme() === 'dark' ? darkLogo : lightLogo;

    if (nextLogo && brandLogo.getAttribute('src') !== nextLogo) {
      brandLogo.setAttribute('src', nextLogo);
    }
  };

  const closeSubmenus = (except?: Element | null) => {
    submenuToggles.forEach((button) => {
      const item = button.closest('.nav-item');
      if (item && item === except) return;
      button.setAttribute('aria-expanded', 'false');
      item?.classList.remove('is-submenu-open');
    });
    syncOpenSubmenuClass();
  };

  const blurFocusedElement = (scope?: Element | null) => {
    const activeElement = document.activeElement;
    if (activeElement instanceof HTMLElement && (!scope || scope.contains(activeElement))) {
      activeElement.blur();
    }
  };

  const setNavOpenState = (isOpen: boolean) => {
    header?.setAttribute('data-nav-open', String(isOpen));
    document.documentElement.toggleAttribute('data-mobile-nav-open', isOpen);
    navToggle?.setAttribute('aria-label', isOpen ? '关闭导航菜单' : '打开导航菜单');
  };

  const closeNav = () => {
    if (!nav || !navToggle) return;
    nav.classList.remove('is-open');
    nav.hidden = mobileNav.matches;
    navToggle.setAttribute('aria-expanded', 'false');
    setNavOpenState(false);
    closeSubmenus();
  };

  const syncNav = () => {
    if (!nav || !navToggle) return;
    if (mobileNav.matches) {
      const isOpen = nav.classList.contains('is-open');
      nav.hidden = !isOpen;
      navToggle.setAttribute('aria-expanded', String(isOpen));
      setNavOpenState(isOpen);
      if (!isOpen) closeSubmenus();
      return;
    }

    nav.hidden = false;
    nav.classList.remove('is-open');
    navToggle.setAttribute('aria-expanded', 'false');
    setNavOpenState(false);
    closeSubmenus();
  };

  const syncThemeToggle = () => {
    if (!themeToggle) return;
    const theme = getEffectiveTheme();
    themeToggle.dataset.theme = theme;
    themeToggle.setAttribute('aria-label', theme === 'dark' ? '切换到浅色主题' : '切换到深色主题');
  };

  syncBrandLogo();
  syncThemeToggle();
  syncNav();

  media.addEventListener('change', () => {
    if (!getStoredTheme()) {
      document.documentElement.removeAttribute('data-theme');
      syncBrandLogo();
      syncThemeToggle();
      window.dispatchEvent(new CustomEvent('xg-theme-change'));
    }
  });

  mobileNav.addEventListener('change', syncNav);

  document.addEventListener('click', (event) => {
    if (!header) {
      return;
    }

    const target = event.target as Node;
    const openItem = nav?.querySelector('.nav-item.is-submenu-open');

    if (mobileNav.matches) {
      if (header.contains(target)) {
        if (openItem && !openItem.contains(target)) {
          closeSubmenus();
        }
        return;
      }
      closeNav();
      return;
    }

    if (touchNav.matches) {
      if (openItem && !openItem.contains(target)) {
        closeSubmenus();
      }
      return;
    }

    if (!header.contains(target)) {
      closeSubmenus();
    }
  });

  nav?.addEventListener('click', (event) => {
    if (mobileNav.matches && event.target === nav) {
      closeNav();
    }
  });

  const toggleSubmenu = (button: HTMLButtonElement, event?: MouseEvent) => {
    const item = button.closest('.nav-item');
    if (!item) return;

    if (!usesClickSubmenus()) {
      const isOpen = item.classList.contains('is-submenu-open');
      if (!isOpen) closeSubmenus(item);
      item.querySelectorAll<HTMLButtonElement>('[data-submenu-toggle]').forEach((toggle) => {
        toggle.setAttribute('aria-expanded', String(!isOpen));
      });
      item.classList.toggle('is-submenu-open', !isOpen);
      syncOpenSubmenuClass();
      if ((event?.detail ?? 0) > 0) {
        button.blur();
      }
      return;
    }

    const isOpen = item.classList.contains('is-submenu-open');
    if (!isOpen) closeSubmenus(item);
    item.querySelectorAll<HTMLButtonElement>('[data-submenu-toggle]').forEach((toggle) => {
      toggle.setAttribute('aria-expanded', String(!isOpen));
    });
    item.classList.toggle('is-submenu-open', !isOpen);
    syncOpenSubmenuClass();
  };

  nav?.querySelectorAll<HTMLAnchorElement>('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (mobileNav.matches) {
        closeNav();
        return;
      }
      closeSubmenus();
    });
  });

  submenuToggles.forEach((button) => {
    button.addEventListener('click', (event) => {
      event.stopPropagation();
      toggleSubmenu(button, event);
    });
  });

  submenuItems.forEach((item) => {
    const closeDesktopSubmenu = () => {
      if (usesClickSubmenus()) return;
      closeSubmenus();
      blurFocusedElement(item);
    };

    item.addEventListener('mouseleave', closeDesktopSubmenu);
    item.addEventListener('pointerleave', closeDesktopSubmenu);
  });

  navToggle?.addEventListener('click', () => {
    if (!nav) return;
    const nextOpen = !nav.classList.contains('is-open');
    nav.classList.toggle('is-open', nextOpen);
    nav.hidden = mobileNav.matches ? !nextOpen : false;
    navToggle.setAttribute('aria-expanded', String(nextOpen));
    setNavOpenState(nextOpen);
    if (!nextOpen) closeSubmenus();
  });

  themeToggle?.addEventListener('click', () => {
    const next = getEffectiveTheme() === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem('theme', next);
    } catch {
      // The visual switch still works for the current page.
    }
    syncBrandLogo();
    syncThemeToggle();
    window.dispatchEvent(new CustomEvent('xg-theme-change'));
  });
</script>
