---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const visible = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 4);
let currentH2 = '';
let currentH3 = '';
const tocHeadings = visible.map((heading) => {
  if (heading.depth === 2) {
    currentH2 = heading.slug;
    currentH3 = '';
  }
  if (heading.depth === 3) {
    currentH3 = heading.slug;
  }

  const parentH2 = heading.depth === 2 ? heading.slug : currentH2;
  const parentH3 = heading.depth === 3 ? heading.slug : currentH3;

  return {
    ...heading,
    parentH2,
    parentH3,
    indent: heading.depth === 2 ? 0 : heading.depth === 3 || !parentH3 ? 1 : 2,
  };
});
---

{tocHeadings.length > 0 && (
  <nav class="toc" aria-label="文章目录" data-toc>
    <h2>文章目录</h2>
    <ol>
      {tocHeadings.map((heading) => (
        <li
          class={`depth-${heading.depth} indent-${heading.indent}`}
          data-toc-item
          data-depth={heading.depth}
          data-parent-h2={heading.parentH2}
          data-parent-h3={heading.parentH3}
        >
          <a href={`#${heading.slug}`} data-toc-link>{heading.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}
