---
import { getSite } from '../../features/core/seo';

const site = getSite();
const beian = site.beian;
const beianUrl = site.beianUrl;
const xgBlogVersion = 'v0.5.7';
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p class="footer-copyright">
      &copy; {site.title}
      {beian && (
        <>
          {' · '}
          <a href={beianUrl} target="_blank" rel="noopener noreferrer">
            {beian}
          </a>
        </>
      )}
    </p>
    <p class="footer-links">
      <a href="/rss.xml" aria-label="RSS" data-tooltip="RSS">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 11a9 9 0 0 1 9 9" />
          <path d="M4 4a16 16 0 0 1 16 16" />
          <circle cx="5" cy="19" r="1" />
        </svg>
      </a>
      <a href="/sitemap.xml" aria-label="网站地图" data-tooltip="网站地图">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M14.106 5.553a2 2 0 0 0 1.788 0l3.659-1.83A1 1 0 0 1 21 4.619v12.764a1 1 0 0 1-.553.894l-4.553 2.277a2 2 0 0 1-1.788 0l-4.212-2.106a2 2 0 0 0-1.788 0l-3.659 1.83A1 1 0 0 1 3 19.382V6.618a1 1 0 0 1 .553-.894l4.553-2.277a2 2 0 0 1 1.788 0z" />
          <path d="M15 5.764v15" />
          <path d="M9 3.236v15" />
        </svg>
      </a>
      <a
        href="https://github.com/verkyer/xg-blog"
        target="_blank"
        rel="noopener noreferrer"
        aria-label={xgBlogVersion}
        data-tooltip={xgBlogVersion}
      >
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10" />
          <path d="M12 16v-4" />
          <path d="M12 8h.01" />
        </svg>
      </a>
    </p>
  </div>
</footer>
