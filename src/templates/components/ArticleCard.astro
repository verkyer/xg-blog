---
import { Image } from 'astro:assets';
import type { Post } from '../../features/core/posts';
import { getPostCover, getPostPath } from '../../features/core/posts';
import PostMeta from './PostMeta.astro';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const cover = getPostCover(post);
const href = getPostPath(post);
const isPinned = post.data.top > 0;
const coverAlt = `${post.data.title} 封面图`;
---

<article class="article-card">
  <a class="card-cover" href={href} aria-label={post.data.title}>
    {typeof cover === 'string' ? (
      <img src={cover} alt={coverAlt} loading="lazy" />
    ) : (
      <Image src={cover} alt={coverAlt} loading="lazy" />
    )}
  </a>
  <div class="card-body">
    <h2>
      <a class="card-title-link" href={href}>
        <span class="card-title-text">
          {isPinned && (
            <span class="card-pin-label">置顶</span>
          )}
          {post.data.title}
        </span>
      </a>
    </h2>
    <p>{post.data.description}</p>
    <PostMeta date={post.data.date} categories={post.data.categories} tags={post.data.tags} compact showTags={false} />
  </div>
</article>
