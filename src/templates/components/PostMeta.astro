---
import { formatDate } from '../../features/core/date';
import { getCategory, getCategoryPath, getTag, getTagPath } from '../../features/core/taxonomy';

interface Props {
  date: Date;
  categories: string[];
  tags: string[];
  compact?: boolean;
  showTags?: boolean;
  readingStats?: {
    words: number;
    minutes: number;
  };
}

const { date, categories, tags, compact = false, showTags = true, readingStats } = Astro.props;
const primaryCategory = getCategory(categories[0]);
const visibleTags = showTags ? tags.slice(0, compact ? 3 : tags.length) : [];
---

<div class:list={['post-meta', { compact }]}>
  <time datetime={date.toISOString()}>
    <svg class="meta-date-icon" viewBox="0 0 18 18" aria-hidden="true">
      <rect x="3.5" y="4.5" width="11" height="10" rx="2" />
      <path d="M6 2.8v3.4M12 2.8v3.4M3.8 7.7h10.4" />
    </svg>
    {formatDate(date)}
  </time>
  <a class="meta-link category" href={getCategoryPath(primaryCategory.slug)}>{primaryCategory.name}</a>
  {readingStats && (
    <span class="reading-stats">
      <svg class="meta-reading-icon" viewBox="0 0 18 18" aria-hidden="true">
        <path d="M5 3.5h5.2l2.8 2.8v8.2H5z" />
        <path d="M10.2 3.5v2.8H13M7.2 9h3.6M7.2 11.5h3.6" />
      </svg>
      共 {readingStats.words} 字 · 约 {readingStats.minutes} 分
    </span>
  )}
  {visibleTags.length > 0 && (
    <span class="meta-tags">
      <svg class="meta-tag-icon" viewBox="0 0 18 18" aria-hidden="true">
        <path d="M3.5 9.7V4.8a1.3 1.3 0 0 1 1.3-1.3h4.9a1.6 1.6 0 0 1 1.1.5l3.4 3.4a1.5 1.5 0 0 1 0 2.1l-4.7 4.7a1.5 1.5 0 0 1-2.1 0L4 10.8a1.6 1.6 0 0 1-.5-1.1Z" />
        <path d="M6.7 6.7h.1" />
      </svg>
      {visibleTags.map((tagSlug) => {
        const tag = getTag(tagSlug);
        return <a class="meta-link tag" href={getTagPath(tag.slug)}>#{tag.name}</a>;
      })}
    </span>
  )}
</div>
