---
import { formatDate } from '../../features/core/date';
import { getCategory, getCategoryPath, getTag, getTagPath } from '../../features/core/taxonomy';

interface Props {
  date: Date;
  categories: string[];
  tags: string[];
  compact?: boolean;
  showTags?: boolean;
  readingStats?: {
    words: number;
    minutes: number;
  };
  showViews?: boolean;
}

const { date, categories, tags, compact = false, showTags = true, readingStats, showViews = false } = Astro.props;
const primaryCategory = getCategory(categories[0]);
const visibleTags = showTags ? tags.slice(0, compact ? 3 : tags.length) : [];
---

<div class:list={['post-meta', { compact }]}>
  <time datetime={date.toISOString()} data-pagefind-ignore>
    <svg class="meta-date-icon" viewBox="0 0 18 18" aria-hidden="true">
      <rect x="3.5" y="4.5" width="11" height="10" rx="2" />
      <path d="M6 2.8v3.4M12 2.8v3.4M3.8 7.7h10.4" />
    </svg>
    {formatDate(date)}
  </time>
  <a class="meta-link category" href={getCategoryPath(primaryCategory.slug)} data-pagefind-ignore>{primaryCategory.name}</a>
  {readingStats && (
    <span class="reading-stats" data-pagefind-ignore>
      <span class="reading-stat">
        <svg class="meta-reading-icon" viewBox="0 0 18 18" aria-hidden="true">
          <path d="M5 3.5h5.2l2.8 2.8v8.2H5z" />
          <path d="M10.2 3.5v2.8H13M7.2 9h3.6M7.2 11.5h3.6" />
        </svg>
        <span>{readingStats.words} 字</span>
      </span>
      <span class="reading-stat">
        <svg class="meta-time-icon" viewBox="0 0 18 18" aria-hidden="true">
          <circle cx="9" cy="9" r="6" />
          <path d="M9 5.7v3.6l2.4 1.4" />
        </svg>
        <span>{readingStats.minutes} 分</span>
      </span>
      {showViews && (
        <span class="reading-stat post-views" aria-label="浏览量">
          <svg class="meta-views-icon" viewBox="0 0 18 18" aria-hidden="true">
            <path d="M2.7 9s2.4-4.1 6.3-4.1 6.3 4.1 6.3 4.1-2.4 4.1-6.3 4.1S2.7 9 2.7 9Z" />
            <circle cx="9" cy="9" r="1.8" />
          </svg>
          <span id="twikoo_visitors">0</span>
        </span>
      )}
    </span>
  )}
  {visibleTags.length > 0 && (
    <span class="meta-tags">
      <svg class="meta-tag-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M13.172 2a2 2 0 0 1 1.414.586l6.71 6.71a2.4 2.4 0 0 1 0 3.408l-4.592 4.592a2.4 2.4 0 0 1-3.408 0l-6.71-6.71A2 2 0 0 1 6 9.172V3a1 1 0 0 1 1-1z" />
        <path d="M2 7v6.172a2 2 0 0 0 .586 1.414l6.71 6.71a2.4 2.4 0 0 0 3.191.193" />
        <circle cx="10.5" cy="6.5" r=".5" fill="currentColor" />
      </svg>
      {visibleTags.map((tagSlug) => {
        const tag = getTag(tagSlug);
        return <a class="meta-link tag" href={getTagPath(tag.slug)}>#{tag.name}</a>;
      })}
    </span>
  )}
</div>
