---
import type { Post } from '../../features/core/posts';
import { getAllCategories } from '../../features/core/taxonomy';

interface Props {
  counts: Map<string, number>;
  posts: Post[];
  limit?: number;
}

const { counts, posts, limit = 5 } = Astro.props;
const categories = await getAllCategories(posts);
const latestByCategory = new Map<string, number>();

for (const post of posts) {
  for (const slug of post.data.categories) {
    latestByCategory.set(slug, Math.max(latestByCategory.get(slug) ?? 0, post.data.date.getTime()));
  }
}

const sorted = [...categories].sort((a, b) => {
  const countDiff = (counts.get(b.slug) ?? 0) - (counts.get(a.slug) ?? 0);

  if (countDiff !== 0) {
    return countDiff;
  }

  return (latestByCategory.get(b.slug) ?? 0) - (latestByCategory.get(a.slug) ?? 0);
});
const visible = sorted.slice(0, limit);
---

<section class="sidebar-card list-card" aria-labelledby="category-title">
  <div class="section-heading">
    <h2 class="title-with-icon" id="category-title">
      <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83z" />
        <path d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12" />
        <path d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17" />
      </svg>
      热门分类
    </h2>
    <a class="more-link" href="/categories">更多</a>
  </div>
  <ul>
    {visible.map((category) => (
      <li>
        <a href={`/categories/${category.slug}`}>
          <span>{category.name}</span>
          <small>{counts.get(category.slug) ?? 0}</small>
        </a>
      </li>
    ))}
  </ul>
</section>
