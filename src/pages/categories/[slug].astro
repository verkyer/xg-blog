---
import ArticleList from '../../templates/components/ArticleList.astro';
import Pagination from '../../templates/components/Pagination.astro';
import BaseLayout from '../../templates/layouts/BaseLayout.astro';
import { filterPostsByCategory, getAllPosts } from '../../features/core/posts';
import { getAllCategories, getCategory } from '../../features/core/taxonomy';

const POSTS_PER_PAGE = 10;

export async function getStaticPaths() {
  const posts = await getAllPosts();
  const categories = await getAllCategories(posts);
  return categories.map((category) => ({ params: { slug: category.slug } }));
}

const { slug } = Astro.params;
const posts = await getAllPosts();
const category = getCategory(slug!);
const filteredPosts = filterPostsByCategory(posts, slug!);
const pagePosts = filteredPosts.slice(0, POSTS_PER_PAGE);
const lastPage = Math.max(1, Math.ceil(filteredPosts.length / POSTS_PER_PAGE));
---

<BaseLayout title={category.name} description={category.description || `${category.name} 分类下的全部文章。`} canonical={`/categories/${category.slug}`}>
  <section class="container narrow page-head category-page-head">
    <div class="page-title-row">
      <h1 class="title-with-icon">
        <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83z" />
          <path d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12" />
          <path d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17" />
        </svg>
        {category.name}
      </h1>
      <span>{filteredPosts.length} 篇文章</span>
    </div>
    <p>{category.description}</p>
  </section>

  <section class="container narrow paginated-article-list">
    <ArticleList posts={pagePosts} />
    <Pagination
      currentPage={1}
      lastPage={lastPage}
      basePath={`/categories/${category.slug}/page`}
      firstPagePath={`/categories/${category.slug}`}
      label={`${category.name} 分类分页`}
    />
  </section>
</BaseLayout>
