---
import BaseLayout from '../../templates/layouts/BaseLayout.astro';
import { getAllPosts } from '../../features/core/posts';
import { countCategories, getAllCategories } from '../../features/core/taxonomy';

const posts = await getAllPosts();
const counts = countCategories(posts);
const categories = await getAllCategories(posts);
---

<BaseLayout title="分类目录" description="小鸽志全部文章分类目录。" canonical="/categories">
  <section class="container page-head">
    <div class="page-title-row">
      <h1 class="title-with-icon">
        <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83z" />
          <path d="M2 12a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 12" />
          <path d="M2 17a1 1 0 0 0 .58.91l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9A1 1 0 0 0 22 17" />
        </svg>
        分类目录
      </h1>
      <span>{categories.length} 个分类</span>
    </div>
  </section>

  <section class="container taxonomy-grid">
    {categories.map((category) => (
      <a class="taxonomy-card" href={`/categories/${category.slug}`}>
        <div class="taxonomy-card-head">
          <h2>{category.name}</h2>
          <span>{counts.get(category.slug) ?? 0} 篇</span>
        </div>
        <p>{category.description}</p>
      </a>
    ))}
  </section>
</BaseLayout>
