---
import { render } from 'astro:content';
import { getAllPages, getPageSlug } from '../features/core/pages';
import ArticleInteractions from '../templates/components/ArticleInteractions.astro';
import Comments from '../templates/components/Comments.astro';
import TableOfContents from '../templates/components/TableOfContents.astro';
import BaseLayout from '../templates/layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const pages = await getAllPages();
  return pages.map((page) => ({
    params: { slug: getPageSlug(page) },
    props: { page },
  }));
}

const { page } = Astro.props;
const { slug } = Astro.params;
const { Content, headings } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description} canonical={`/${slug}`}>
  <article class="container article-layout">
    <div class="article-main">
      <header class="article-header">
        <h1>{page.data.title}</h1>
      </header>
      <div class="prose">
        <Content />
      </div>
      <Comments enabled={page.data.comments} path={`/${slug}`} />
    </div>
    <aside class="article-aside">
      <TableOfContents headings={headings} />
    </aside>
  </article>
  <ArticleInteractions />
</BaseLayout>
