---
import BaseLayout from '../templates/layouts/BaseLayout.astro';
import { linkData } from '../features/core/data';

const allLinks = linkData;
---

<BaseLayout title="友情链接" description="小鸽志友情链接和常用资源。" canonical="/links">
  <section class="container page-head">
    <h1 class="title-with-icon">
      <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
      </svg>
      友情链接
    </h1>
  </section>

  <section class="container link-groups">
    {allLinks.map((group, index) => (
      <section class="link-group" aria-labelledby={`link-group-${index}`}>
        <h2 id={`link-group-${index}`}>{group.name}</h2>
        <div class="taxonomy-grid">
          {group.links.map((link) => (
            <a class="taxonomy-card link-card" href={link.url} target="_blank" rel="noopener noreferrer">
              <div class="link-card-head">
                {link.icon && <img class="link-avatar" src={link.icon} alt="" loading="lazy" />}
                <h3>{link.name}</h3>
              </div>
              <p>{link.desc}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </section>
</BaseLayout>
