---
import ArticleList from '../templates/components/ArticleList.astro';
import HomeBanner from '../templates/components/HomeBanner.astro';
import Pagination from '../templates/components/Pagination.astro';
import Sidebar from '../templates/components/Sidebar.astro';
import BaseLayout from '../templates/layouts/BaseLayout.astro';
import { bannerData } from '../features/core/data';
import { getAllPosts } from '../features/core/posts';
import { getSite } from '../features/core/seo';

const POSTS_PER_PAGE = 10;
const posts = await getAllPosts();
const pagePosts = posts.slice(0, POSTS_PER_PAGE);
const lastPage = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
const site = getSite();
---

<BaseLayout description={site.description}>
  <div class="container page-grid">
    <section class="main-column" aria-label="最新文章">
      <HomeBanner items={bannerData} />
      <ArticleList posts={pagePosts} />
      <Pagination currentPage={1} lastPage={lastPage} basePath="/page" firstPagePath="/" />
    </section>
    <Sidebar posts={posts} />
  </div>
</BaseLayout>
