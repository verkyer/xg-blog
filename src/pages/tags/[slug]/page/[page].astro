---
import type { GetStaticPaths, Page } from 'astro';
import type { TaxonomyItem } from '../../../../features/core/data';
import ArticleList from '../../../../templates/components/ArticleList.astro';
import Pagination from '../../../../templates/components/Pagination.astro';
import BaseLayout from '../../../../templates/layouts/BaseLayout.astro';
import { filterPostsByTag, getAllPosts, type Post } from '../../../../features/core/posts';
import { getAllTags } from '../../../../features/core/taxonomy';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getAllPosts();
  const tags = await getAllTags(posts);

  return tags.flatMap((tag) =>
    paginate(filterPostsByTag(posts, tag.slug), {
      pageSize: 10,
      params: { slug: tag.slug },
      props: { tag },
    }),
  );
}) satisfies GetStaticPaths;

interface Props {
  page: Page<Post>;
  tag: TaxonomyItem;
}

const { page, tag } = Astro.props;
const title = page.currentPage === 1 ? `#${tag.name}` : `#${tag.name} - 第 ${page.currentPage} 页`;
const canonical = page.currentPage === 1 ? `/tags/${tag.slug}` : `/tags/${tag.slug}/page/${page.currentPage}`;
---

<BaseLayout title={title} description={`标签 #${tag.name} 下的全部文章。`} canonical={canonical}>
  <section class="container narrow page-head">
    <div class="page-title-row">
      <h1 class="title-with-icon">
        <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M13.172 2a2 2 0 0 1 1.414.586l6.71 6.71a2.4 2.4 0 0 1 0 3.408l-4.592 4.592a2.4 2.4 0 0 1-3.408 0l-6.71-6.71A2 2 0 0 1 6 9.172V3a1 1 0 0 1 1-1z" />
          <path d="M2 7v6.172a2 2 0 0 0 .586 1.414l6.71 6.71a2.4 2.4 0 0 0 3.191.193" />
          <circle cx="10.5" cy="6.5" r=".5" fill="currentColor" />
        </svg>
        {tag.name}
      </h1>
      <span>{page.total} 篇文章</span>
    </div>
  </section>

  <section class="container narrow paginated-article-list">
    <ArticleList posts={page.data} />
    <Pagination
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      basePath={`/tags/${tag.slug}/page`}
      firstPagePath={`/tags/${tag.slug}`}
      label={`标签 ${tag.name} 分页`}
    />
  </section>
</BaseLayout>
