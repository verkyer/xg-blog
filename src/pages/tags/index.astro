---
import BaseLayout from '../../templates/layouts/BaseLayout.astro';
import { getAllPosts } from '../../features/core/posts';
import { countTags, getAllTags } from '../../features/core/taxonomy';

const posts = await getAllPosts();
const counts = countTags(posts);
const tags = await getAllTags(posts);
const sortedTags = [...tags].sort((a, b) => (counts.get(b.slug) ?? 0) - (counts.get(a.slug) ?? 0));
---

<BaseLayout title="标签" description="小鸽志全部文章标签。" canonical="/tags">
  <section class="container page-head">
    <div class="page-title-row">
      <h1 class="title-with-icon">
        <svg class="title-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M13.172 2a2 2 0 0 1 1.414.586l6.71 6.71a2.4 2.4 0 0 1 0 3.408l-4.592 4.592a2.4 2.4 0 0 1-3.408 0l-6.71-6.71A2 2 0 0 1 6 9.172V3a1 1 0 0 1 1-1z" />
          <path d="M2 7v6.172a2 2 0 0 0 .586 1.414l6.71 6.71a2.4 2.4 0 0 0 3.191.193" />
          <circle cx="10.5" cy="6.5" r=".5" fill="currentColor" />
        </svg>
        标签
      </h1>
      <span>{sortedTags.length} 个标签</span>
    </div>
  </section>

  <section class="container tag-index">
    {sortedTags.map((tag) => (
      <a href={`/tags/${tag.slug}`}>#{tag.name}<small>{counts.get(tag.slug) ?? 0}</small></a>
    ))}
  </section>
</BaseLayout>
