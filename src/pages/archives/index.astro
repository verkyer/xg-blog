---
import BaseLayout from '../../templates/layouts/BaseLayout.astro';
import { formatDate } from '../../features/core/date';
import { getAllPosts, getPostPath, groupPostsByMonth } from '../../features/core/posts';

const posts = await getAllPosts();
const groups = groupPostsByMonth(posts);
---

<BaseLayout title="文章归档" description="小鸽志全部文章按发布时间归档。" canonical="/archives">
  <section class="container narrow page-head">
    <h1>文章归档</h1>
  </section>

  <section class="container narrow archive-list">
    {groups.map((group) => (
      <section class="archive-group" aria-labelledby={`archive-${group.month}`}>
        <h2 id={`archive-${group.month}`}>{group.month}</h2>
        <ul>
          {group.posts.map((post) => (
            <li>
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <a href={getPostPath(post)}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>
</BaseLayout>
