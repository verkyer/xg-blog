---
import { getImage } from 'astro:assets';
import { render } from 'astro:content';
import ArticleInteractions from '../../templates/components/ArticleInteractions.astro';
import PostMeta from '../../templates/components/PostMeta.astro';
import TableOfContents from '../../templates/components/TableOfContents.astro';
import BaseLayout from '../../templates/layouts/BaseLayout.astro';
import { getAllPosts, getPostCover, getPostPath, getPostSlug, getReadingStats } from '../../features/core/posts';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const cover = getPostCover(post);
const seoImage = typeof cover === 'string' ? cover : (await getImage({ src: cover })).src;
const readingStats = getReadingStats(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={getPostPath(post)}
  image={seoImage}
  type="article"
  publishedTime={post.data.date}
>
  <article class="container article-layout">
    <div class="article-main" data-pagefind-body>
      <header class="article-header">
        <h1>{post.data.title}</h1>
        <PostMeta date={post.data.date} categories={post.data.categories} tags={post.data.tags} readingStats={readingStats} />
      </header>
      <div class="prose">
        <Content />
      </div>
    </div>
    <aside class="article-aside" data-pagefind-ignore>
      <TableOfContents headings={headings} />
    </aside>
  </article>
  <script>
    document.querySelectorAll('.article-main .prose a').forEach((link) => {
      const href = link.getAttribute('href');
      if (href && !href.startsWith('#')) {
        link.setAttribute('target', '_blank');
        link.setAttribute('rel', 'noopener noreferrer');
      }
    });
  </script>
  <ArticleInteractions />
</BaseLayout>
